# 类案检索助手 · 环境变量样例（Day 0 · 4.1）
# 复制为 .env 后填值，或优先配置到系统环境变量。.env 不入库（见 .gitignore）。
# 安全红线：密钥仅在启动时校验“是否存在”，绝不打印值、绝不写日志。

# --- LLM 密钥（启动只校验存在性）---
# 推荐使用系统环境变量 DEEPSEEK_API_KEY；本文件仅作本地兜底。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_COMPLETIONS_PATH=/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat
QUERY_REWRITE_TIMEOUT_SECONDS=5
ENABLE_QUERY_REWRITE=false
SUMMARY_TIMEOUT_SECONDS=5
ENABLE_SUMMARY=false
ENABLE_EXPANDED_SEARCH=false

# --- Query processing ---
QUERY_MAX_LENGTH=5000
QUERY_MIN_SEMANTIC_LENGTH=4

# --- Fact similarity rerank ---
# Day 1 keeps this disabled by default until Day 3 eval/gray release.
ENABLE_WEIGHTED_RERANK=false
RERANK_WEIGHT_VECTOR_SIMILARITY=0.55
RERANK_WEIGHT_LEGAL_ELEMENT_OVERLAP=0.20
RERANK_WEIGHT_CASE_CAUSE_MATCH=0.10
RERANK_WEIGHT_KEY_PARAGRAPH_MATCH=0.10
RERANK_WEIGHT_AUTHORITY_SIGNAL=0.05

# --- M4 工作流沉淀开关（M4-1 合同冻结：默认全部 false，安全态）---
# 仅声明开关位；关闭时回到 M3 末态，不改变标准搜索默认行为、排序或 rerank 默认。
# M4-2 至 M4-7 才逐步实现对应能力，且每个能力都必须可关闭/可降级。
ENABLE_SEARCH_HISTORY=false
ENABLE_CASE_FAVORITE=false
ENABLE_CASE_LIST=false
ENABLE_LIST_EXPORT=false
ENABLE_REPORT_TEMPLATE=false
ENABLE_TEAM_REUSE=false

# --- M5 商业化扩展开关（M5-1 合同冻结：默认全部 false，安全态）---
# 仅声明开关位；关闭时回到 M4 末态（单用户、纯前端沉淀），不改变标准搜索默认行为、
# 排序或 rerank 默认。M5-2 至 M5-9 才逐步实现账号/团队隔离/权限/共享/导入/计费，
# 且每个能力都必须可关闭/可降级；凭据类绝不在工具内代填代管代存明文。
ENABLE_ACCOUNT_SYSTEM=false
ENABLE_TEAM_WORKSPACE=false
ENABLE_PERMISSION_TIERING=false
ENABLE_TEAM_SHARING=false
ENABLE_BULK_IMPORT=false
ENABLE_BILLING=false

# --- E 系列多产品生态开关（E-1 合同冻结：默认全部 false，安全态）---
# 仅声明开关位；关闭时回到 M5-10 单产品末态，不改变标准搜索默认行为、排序、
# source selection 或 rerank 默认开关。E-1 不建任何产品包、不抽内核、不暴露检索服务、
# 不注册端点、不接线前端入口。ENABLE_ECOSYSTEM 为生态总开关，与 4 个产品子开关正交；
# E-4 至 E-7 才逐个实现 on 路径，且每个产品都必须可关闭/可降级、不默认开启跨用户可见性。
ENABLE_ECOSYSTEM=false
ENABLE_INTAKE=false
ENABLE_STATUTE_SEARCH=false
ENABLE_DRAFTING=false
ENABLE_CASEBOOK=false

# E4 案情录入端二级 flag（E4-1 仅声明，不接线、无 on 路径）。
# 服务端 AI 增强抽取子开关，正交于 ENABLE_INTAKE。默认 false：脱敏与要素抽取纯浏览器本地完成，
# 原始案情零上送；服务端增强为后期可选项，本期只冻结不接线。任一默认 true 即 E4 NO_GO。
ENABLE_INTAKE_AI_EXTRACTION=false

# --- Embedding / 向量库口径（query 与文书必须完全一致）---
# 向量模型本地部署：Ollama bge-m3，1024 维，数据不出本机，无需 API 密钥。
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSION=1024
EMBEDDING_DISTANCE_METRIC=cosine
EMBEDDING_TIMEOUT_SECONDS=10
OLLAMA_BASE_URL=http://localhost:11434
CHROMA_COLLECTION=case_chunks_bge_m3_v1
# 默认走仓库内的 ./data/chroma；如果你的 Windows 检出路径含非 ASCII，可改成自定义 ASCII 目录。
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_QUERY_TIMEOUT_SECONDS=3

# --- 基础设施 ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/case_search
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO

# --- Web feature flags ---
# Vite 仅暴露 VITE_ 前缀变量；此项为 ENABLE_EXPANDED_SEARCH 的前端入口镜像。
VITE_ENABLE_EXPANDED_SEARCH=false
# M4-2 检索历史与草稿恢复前端入口（默认 false / 关闭即回到 M3 末态）。
VITE_ENABLE_SEARCH_HISTORY=false
# M4-3 案例收藏前端入口（默认 false / 关闭即回到 M4-2 末态）。
VITE_ENABLE_CASE_FAVORITE=false
# M4-4 类案清单组装前端入口（默认 false / 关闭即回到 M4-3 末态）。
VITE_ENABLE_CASE_LIST=false
# M4-5 类案清单导出前端入口（默认 false / 关闭即回到 M4-4 末态）。
VITE_ENABLE_LIST_EXPORT=false
# M4-6 轻量报告模板生成前端入口（默认 false / 关闭即回到 M4-5 末态）。
VITE_ENABLE_REPORT_TEMPLATE=false
# M5-2 账号体系前端入口（默认 false / 关闭即回到 M4 单用户私有末态）。
# 凭据由用户在平台侧输入；前端不代填密码/SSO，会话令牌仅内存运行态、不写本地存储。
VITE_ENABLE_ACCOUNT_SYSTEM=false
# M5-3 团队空间与数据隔离前端入口（默认 false / 关闭即回到 M5-2/M4 单用户私有末态）。
# 开启后团队空间只展示脱敏的团队/成员结构化关系，沉淀对象按 team_id 强隔离、跨团队不可见。
VITE_ENABLE_TEAM_WORKSPACE=false
# M5-4 权限分级与对象级访问控制前端入口（默认 false / 关闭即回到 M5-3/M4 末态）。
# 开启后仅展示脱敏角色/授权信息；每次对象读写由后端对象级鉴权强制，越权 403；默认最小权限。
VITE_ENABLE_PERMISSION_TIERING=false
# M5-5 沉淀同步与团队共享前端入口（默认 false / 关闭即回到 M4 本地沉淀末态）。
# 开启后同步只上送元数据/引用/来源锚点/用户自填短字段，绝不上送正文；共享需显式动作、默认私有。
VITE_ENABLE_TEAM_SHARING=false
# M5-6 批量导入前端入口（默认 false / 关闭即回到 M5-5/M4 末态）。
# 开启后仅展示导入入口/进度/结果；导入只含元数据/引用/来源锚点/用户自填短字段，绝不含正文；
# 导入对象默认归属当前 owner、默认私有；缺锚点项被降级或拒绝，不伪造锚点；导入不改变主排序。
VITE_ENABLE_BULK_IMPORT=false
# M5-9 商业化闭环（套餐/试用/计费/续费意愿）前端入口（默认 false / 关闭即回到 M5-6 末态）。
# 仅展示套餐目录、试用、续费意愿采集与脱敏订阅状态；绝不代填/代管/代存任何支付凭据，
# 支付由平台侧/第三方完成。后端 ENABLE_BILLING=false 时即便前端开启也会被 403 拦截。
VITE_ENABLE_BILLING=false

# --- E 系列多产品生态前端镜像开关（E-1 合同冻结：默认全部 false，安全态）---
# E-1 仅声明，不渲染任何跨产品入口/导航、不接线任何产品前端。关闭即回到 M5-10 单产品末态。
# ENABLE_ECOSYSTEM 控制是否暴露「多产品」枢纽本身；4 个子开关控制单个产品入口是否渲染。
# 后端对应 ENABLE_* 为 false 时，即便前端镜像开启也不会有任何可用端点（E-4~E-7 才接线）。
VITE_ENABLE_ECOSYSTEM=false
VITE_ENABLE_INTAKE=false
VITE_ENABLE_STATUTE_SEARCH=false
VITE_ENABLE_DRAFTING=false
VITE_ENABLE_CASEBOOK=false

# E4 案情录入端二级 flag 前端镜像（E4-1 仅声明，默认 false，不接线、不渲染、无 on 路径）。
# 与后端 ENABLE_INTAKE_AI_EXTRACTION 对应；脱敏纯浏览器本地完成，原始案情零上送服务端。
VITE_ENABLE_INTAKE_AI_EXTRACTION=false
